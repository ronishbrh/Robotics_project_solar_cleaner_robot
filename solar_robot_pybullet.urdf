<?xml version="1.0"?>
<robot name="solar_cleaning_robot">

<!--
  ╔══════════════════════════════════════════════════════════════════╗
  ║  SOLAR PANEL CLEANING ROBOT  –  Inclined-Panel Ready            ║
  ╠══════════════════════════════════════════════════════════════════╣
  ║                                                                  ║
  ║  SUCTION SYSTEM                                                  ║
  ║    • 4 wheel-corner suction pads (always in contact)            ║
  ║    • 2 front bridge tip pads  (active on next panel)            ║
  ║    • 2 rear  bridge tip pads  (active on previous panel)        ║
  ║    • PyBullet constraint force applied along -panel_normal       ║
  ║      in SuctionSystem class (not a joint – a force)             ║
  ║                                                                  ║
  ║  BODY LIFT JOINT                                                 ║
  ║    body_lift_joint  prismatic Z  0 → 0.050 m                    ║
  ║    Lifts wheels clear of panel for gap traversal                 ║
  ║                                                                  ║
  ║  BRIDGE                                                          ║
  ║    front/rear_bridge_extend1  prismatic  0 → 0.40 m             ║
  ║    front/rear_bridge_extend2  prismatic  0 → 0.30 m             ║
  ║    Tip at full extension: ~1.05 m from body centre              ║
  ║                                                                  ║
  ║  ACTIVE SUCTION LEGS (bridge tip, prismatic -Z)                  ║
  ║    front/rear_suction_left/right_joint  0 → 0.050 m             ║
  ╚══════════════════════════════════════════════════════════════════╝
-->

<!-- ═══════════════ MATERIALS ═══════════════ -->
<material name="blue">   <color rgba="0.2  0.3  0.8  1"/></material>
<material name="dark_blue"><color rgba="0.1 0.15 0.5  1"/></material>
<material name="black">  <color rgba="0.1  0.1  0.1  1"/></material>
<material name="silver">  <color rgba="0.72 0.72 0.72 1"/></material>
<material name="orange">  <color rgba="1.0  0.45 0.0  1"/></material>
<material name="red">     <color rgba="0.85 0.1  0.1  1"/></material>
<material name="green">   <color rgba="0.1  0.75 0.2  1"/></material>
<material name="yellow">  <color rgba="0.95 0.85 0.1  1"/></material>


<!-- ═══════════════ BASE LINK ═══════════════ -->
<link name="base_link"/>


<!-- ═══════════════ BODY LIFT ═══════════════ -->
<link name="lift_column">
  <inertial>
    <origin xyz="0 0 0"/>
    <mass value="0.05"/>
    <inertia ixx="0.00001" ixy="0" ixz="0"
             iyy="0.00001" iyz="0" izz="0.00001"/>
  </inertial>
  <visual>
    <geometry><box size="0.03 0.03 0.06"/></geometry>
    <material name="dark_blue"/>
  </visual>
</link>
<joint name="body_lift_joint" type="prismatic">
  <parent link="base_link"/>
  <child  link="lift_column"/>
  <origin xyz="0 0 0"/>
  <axis xyz="0 0 1"/>
  <limit lower="0" upper="0.050" effort="400" velocity="0.06"/>
  <dynamics damping="25" friction="8"/>
</joint>


<!-- ═══════════════ MAIN BODY ═══════════════ -->
<link name="main_body">
  <inertial>
    <origin xyz="0 0 0"/>
    <mass value="3.2"/>
    <inertia ixx="0.038" ixy="0" ixz="0"
             iyy="0.028" iyz="0" izz="0.055"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0"/>
    <geometry><box size="0.45 0.35 0.12"/></geometry>
    <material name="blue"/>
  </visual>
  <collision>
    <origin xyz="0 0 0"/>
    <geometry><box size="0.45 0.35 0.12"/></geometry>
  </collision>
</link>
<joint name="body_to_chassis" type="fixed">
  <parent link="lift_column"/>
  <child  link="main_body"/>
  <origin xyz="0 0 0"/>
</joint>


<!-- ═══════════════ SENSORS ═══════════════ -->
<link name="lidar">
  <visual><geometry><cylinder radius="0.038" length="0.04"/></geometry>
    <material name="black"/></visual>
</link>
<joint name="lidar_joint" type="fixed">
  <parent link="main_body"/><child link="lidar"/>
  <origin xyz="0 0 0.08"/>
</joint>

<link name="camera">
  <visual><geometry><box size="0.05 0.025 0.025"/></geometry>
    <material name="black"/></visual>
</link>
<joint name="camera_joint" type="fixed">
  <parent link="main_body"/><child link="camera"/>
  <origin xyz="0.225 0 0.04"/>
</joint>


<!-- ═══════════════ CLEANING BRUSH ═══════════════ -->
<link name="brush">
  <inertial>
    <origin xyz="0 0 0"/>
    <mass value="0.14"/>
    <inertia ixx="0.0002" ixy="0" ixz="0"
             iyy="0.0002" iyz="0" izz="0.0002"/>
  </inertial>
  <visual>
    <geometry><cylinder radius="0.038" length="0.32"/></geometry>
    <material name="orange"/>
  </visual>
  <collision>
    <geometry><cylinder radius="0.038" length="0.32"/></geometry>
  </collision>
</link>
<joint name="brush_joint" type="continuous">
  <parent link="main_body"/><child link="brush"/>
  <origin xyz="0.20 0 -0.055" rpy="0 1.5708 0"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="0.05" friction="0.02"/>
</joint>


<!-- ═══════════════════════════════════════════════════ -->
<!--  WHEELS  (plain rolling wheels, no suction pads)    -->
<!--  Suction for inclined panels is handled entirely    -->
<!--  via applyExternalForce in the Python environment.  -->
<!--  Fixed suction pads at wheel level block movement.  -->
<!-- ═══════════════════════════════════════════════════ -->

<!-- ── Front-Left ── -->
<link name="wheel_fl">
  <inertial><origin xyz="0 0 0"/><mass value="0.20"/>
    <inertia ixx="0.00015" ixy="0" ixz="0"
             iyy="0.00015" iyz="0" izz="0.00025"/></inertial>
  <visual><geometry><cylinder radius="0.035" length="0.022"/></geometry>
    <material name="black"/></visual>
  <collision><geometry><cylinder radius="0.035" length="0.022"/></geometry></collision>
</link>
<joint name="wheel_fl_joint" type="continuous">
  <parent link="main_body"/><child link="wheel_fl"/>
  <origin xyz="0.18 0.175 -0.07" rpy="1.5708 0 0"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="0.0" friction="0.0"/>
</joint>

<!-- ── Front-Right ── -->
<link name="wheel_fr">
  <inertial><origin xyz="0 0 0"/><mass value="0.20"/>
    <inertia ixx="0.00015" ixy="0" ixz="0"
             iyy="0.00015" iyz="0" izz="0.00025"/></inertial>
  <visual><geometry><cylinder radius="0.035" length="0.022"/></geometry>
    <material name="black"/></visual>
  <collision><geometry><cylinder radius="0.035" length="0.022"/></geometry></collision>
</link>
<joint name="wheel_fr_joint" type="continuous">
  <parent link="main_body"/><child link="wheel_fr"/>
  <origin xyz="0.18 -0.175 -0.07" rpy="1.5708 0 0"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="0.0" friction="0.0"/>
</joint>

<!-- ── Rear-Left ── -->
<link name="wheel_rl">
  <inertial><origin xyz="0 0 0"/><mass value="0.20"/>
    <inertia ixx="0.00015" ixy="0" ixz="0"
             iyy="0.00015" iyz="0" izz="0.00025"/></inertial>
  <visual><geometry><cylinder radius="0.035" length="0.022"/></geometry>
    <material name="black"/></visual>
  <collision><geometry><cylinder radius="0.035" length="0.022"/></geometry></collision>
</link>
<joint name="wheel_rl_joint" type="continuous">
  <parent link="main_body"/><child link="wheel_rl"/>
  <origin xyz="-0.18 0.175 -0.07" rpy="1.5708 0 0"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="0.0" friction="0.0"/>
</joint>

<!-- ── Rear-Right ── -->
<link name="wheel_rr">
  <inertial><origin xyz="0 0 0"/><mass value="0.20"/>
    <inertia ixx="0.00015" ixy="0" ixz="0"
             iyy="0.00015" iyz="0" izz="0.00025"/></inertial>
  <visual><geometry><cylinder radius="0.035" length="0.022"/></geometry>
    <material name="black"/></visual>
  <collision><geometry><cylinder radius="0.035" length="0.022"/></geometry></collision>
</link>
<joint name="wheel_rr_joint" type="continuous">
  <parent link="main_body"/><child link="wheel_rr"/>
  <origin xyz="-0.18 -0.175 -0.07" rpy="1.5708 0 0"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="0.0" friction="0.0"/>
</joint>


<!-- ═══════════════════════════════════════════════════ -->
<!--  FRONT BRIDGE  (extends in +X direction)            -->
<!-- ═══════════════════════════════════════════════════ -->

<link name="front_bridge_base">
  <visual><origin xyz="0 0 0"/>
    <geometry><box size="0.10 0.22 0.038"/></geometry>
    <material name="silver"/></visual>
  <collision><origin xyz="0 0 0"/>
    <geometry><box size="0.10 0.22 0.038"/></geometry></collision>
</link>
<joint name="front_bridge_mount" type="fixed">
  <parent link="main_body"/><child link="front_bridge_base"/>
  <origin xyz="0.18 0 0.010"/>
</joint>

<link name="front_bridge_seg1">
  <inertial><origin xyz="0 0 0"/><mass value="0.11"/>
    <inertia ixx="0.00018" ixy="0" ixz="0"
             iyy="0.00018" iyz="0" izz="0.000045"/></inertial>
  <visual><origin xyz="0 0 0"/>
    <geometry><box size="0.15 0.14 0.024"/></geometry>
    <material name="silver"/></visual>
  <collision><origin xyz="0 0 0"/>
    <geometry><box size="0.15 0.14 0.024"/></geometry></collision>
</link>
<joint name="front_bridge_extend1" type="prismatic">
  <parent link="front_bridge_base"/><child link="front_bridge_seg1"/>
  <origin xyz="0.05 0 0"/>
  <axis xyz="1 0 0"/>
  <limit lower="0" upper="0.40" effort="250" velocity="0.20"/>
  <dynamics damping="2.0" friction="0.5"/>
</joint>

<link name="front_bridge_seg2">
  <inertial><origin xyz="0 0 0"/><mass value="0.09"/>
    <inertia ixx="0.00013" ixy="0" ixz="0"
             iyy="0.00013" iyz="0" izz="0.000035"/></inertial>
  <visual><origin xyz="0 0 0"/>
    <geometry><box size="0.15 0.12 0.020"/></geometry>
    <material name="silver"/></visual>
  <collision><origin xyz="0 0 0"/>
    <geometry><box size="0.15 0.12 0.020"/></geometry></collision>
</link>
<joint name="front_bridge_extend2" type="prismatic">
  <parent link="front_bridge_seg1"/><child link="front_bridge_seg2"/>
  <origin xyz="0.15 0 0"/>
  <axis xyz="1 0 0"/>
  <limit lower="0" upper="0.30" effort="200" velocity="0.20"/>
  <dynamics damping="1.5" friction="0.5"/>
</joint>

<!-- Front bridge tip suction legs -->
<link name="front_suction_left">
  <inertial><origin xyz="0 0 0"/><mass value="0.03"/>
    <inertia ixx="0.00001" ixy="0" ixz="0"
             iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  <visual><origin xyz="0 0 -0.014"/>
    <geometry><cylinder radius="0.007" length="0.028"/></geometry>
    <material name="dark_blue"/></visual>
</link>
<link name="front_pad_left">
  <inertial><origin xyz="0 0 0"/><mass value="0.015"/>
    <inertia ixx="0.000008" ixy="0" ixz="0"
             iyy="0.000008" iyz="0" izz="0.000008"/></inertial>
  <visual><geometry><cylinder radius="0.026" length="0.007"/></geometry>
    <material name="red"/></visual>
  <collision><geometry><cylinder radius="0.026" length="0.007"/></geometry></collision>
</link>
<joint name="front_suction_left_joint" type="prismatic">
  <parent link="front_bridge_seg2"/><child link="front_suction_left"/>
  <origin xyz="0.07 0.07 -0.005"/>
  <axis xyz="0 0 -1"/>
  <limit lower="0" upper="0.050" effort="120" velocity="0.08"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>
<joint name="front_pad_left_joint" type="fixed">
  <parent link="front_suction_left"/><child link="front_pad_left"/>
  <origin xyz="0 0 -0.032"/>
</joint>

<link name="front_suction_right">
  <inertial><origin xyz="0 0 0"/><mass value="0.03"/>
    <inertia ixx="0.00001" ixy="0" ixz="0"
             iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  <visual><origin xyz="0 0 -0.014"/>
    <geometry><cylinder radius="0.007" length="0.028"/></geometry>
    <material name="dark_blue"/></visual>
</link>
<link name="front_pad_right">
  <inertial><origin xyz="0 0 0"/><mass value="0.015"/>
    <inertia ixx="0.000008" ixy="0" ixz="0"
             iyy="0.000008" iyz="0" izz="0.000008"/></inertial>
  <visual><geometry><cylinder radius="0.026" length="0.007"/></geometry>
    <material name="red"/></visual>
  <collision><geometry><cylinder radius="0.026" length="0.007"/></geometry></collision>
</link>
<joint name="front_suction_right_joint" type="prismatic">
  <parent link="front_bridge_seg2"/><child link="front_suction_right"/>
  <origin xyz="0.07 -0.07 -0.005"/>
  <axis xyz="0 0 -1"/>
  <limit lower="0" upper="0.050" effort="120" velocity="0.08"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>
<joint name="front_pad_right_joint" type="fixed">
  <parent link="front_suction_right"/><child link="front_pad_right"/>
  <origin xyz="0 0 -0.032"/>
</joint>


<!-- ═══════════════════════════════════════════════════ -->
<!--  REAR BRIDGE  (extends in -X direction)             -->
<!-- ═══════════════════════════════════════════════════ -->

<link name="rear_bridge_base">
  <visual><origin xyz="0 0 0"/>
    <geometry><box size="0.10 0.22 0.038"/></geometry>
    <material name="silver"/></visual>
  <collision><origin xyz="0 0 0"/>
    <geometry><box size="0.10 0.22 0.038"/></geometry></collision>
</link>
<joint name="rear_bridge_mount" type="fixed">
  <parent link="main_body"/><child link="rear_bridge_base"/>
  <origin xyz="-0.18 0 0.010"/>
</joint>

<link name="rear_bridge_seg1">
  <inertial><origin xyz="0 0 0"/><mass value="0.11"/>
    <inertia ixx="0.00018" ixy="0" ixz="0"
             iyy="0.00018" iyz="0" izz="0.000045"/></inertial>
  <visual><origin xyz="0 0 0"/>
    <geometry><box size="0.15 0.14 0.024"/></geometry>
    <material name="silver"/></visual>
  <collision><origin xyz="0 0 0"/>
    <geometry><box size="0.15 0.14 0.024"/></geometry></collision>
</link>
<joint name="rear_bridge_extend1" type="prismatic">
  <parent link="rear_bridge_base"/><child link="rear_bridge_seg1"/>
  <origin xyz="-0.05 0 0"/>
  <axis xyz="-1 0 0"/>
  <limit lower="0" upper="0.40" effort="250" velocity="0.20"/>
  <dynamics damping="2.0" friction="0.5"/>
</joint>

<link name="rear_bridge_seg2">
  <inertial><origin xyz="0 0 0"/><mass value="0.09"/>
    <inertia ixx="0.00013" ixy="0" ixz="0"
             iyy="0.00013" iyz="0" izz="0.000035"/></inertial>
  <visual><origin xyz="0 0 0"/>
    <geometry><box size="0.15 0.12 0.020"/></geometry>
    <material name="silver"/></visual>
  <collision><origin xyz="0 0 0"/>
    <geometry><box size="0.15 0.12 0.020"/></geometry></collision>
</link>
<joint name="rear_bridge_extend2" type="prismatic">
  <parent link="rear_bridge_seg1"/><child link="rear_bridge_seg2"/>
  <origin xyz="-0.15 0 0"/>
  <axis xyz="-1 0 0"/>
  <limit lower="0" upper="0.30" effort="200" velocity="0.20"/>
  <dynamics damping="1.5" friction="0.5"/>
</joint>

<!-- Rear bridge tip suction legs -->
<link name="rear_suction_left">
  <inertial><origin xyz="0 0 0"/><mass value="0.03"/>
    <inertia ixx="0.00001" ixy="0" ixz="0"
             iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  <visual><origin xyz="0 0 -0.014"/>
    <geometry><cylinder radius="0.007" length="0.028"/></geometry>
    <material name="dark_blue"/></visual>
</link>
<link name="rear_pad_left">
  <inertial><origin xyz="0 0 0"/><mass value="0.015"/>
    <inertia ixx="0.000008" ixy="0" ixz="0"
             iyy="0.000008" iyz="0" izz="0.000008"/></inertial>
  <visual><geometry><cylinder radius="0.026" length="0.007"/></geometry>
    <material name="green"/></visual>
  <collision><geometry><cylinder radius="0.026" length="0.007"/></geometry></collision>
</link>
<joint name="rear_suction_left_joint" type="prismatic">
  <parent link="rear_bridge_seg2"/><child link="rear_suction_left"/>
  <origin xyz="-0.07 0.07 -0.005"/>
  <axis xyz="0 0 -1"/>
  <limit lower="0" upper="0.050" effort="120" velocity="0.08"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>
<joint name="rear_pad_left_joint" type="fixed">
  <parent link="rear_suction_left"/><child link="rear_pad_left"/>
  <origin xyz="0 0 -0.032"/>
</joint>

<link name="rear_suction_right">
  <inertial><origin xyz="0 0 0"/><mass value="0.03"/>
    <inertia ixx="0.00001" ixy="0" ixz="0"
             iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  <visual><origin xyz="0 0 -0.014"/>
    <geometry><cylinder radius="0.007" length="0.028"/></geometry>
    <material name="dark_blue"/></visual>
</link>
<link name="rear_pad_right">
  <inertial><origin xyz="0 0 0"/><mass value="0.015"/>
    <inertia ixx="0.000008" ixy="0" ixz="0"
             iyy="0.000008" iyz="0" izz="0.000008"/></inertial>
  <visual><geometry><cylinder radius="0.026" length="0.007"/></geometry>
    <material name="green"/></visual>
  <collision><geometry><cylinder radius="0.026" length="0.007"/></geometry></collision>
</link>
<joint name="rear_suction_right_joint" type="prismatic">
  <parent link="rear_bridge_seg2"/><child link="rear_suction_right"/>
  <origin xyz="-0.07 -0.07 -0.005"/>
  <axis xyz="0 0 -1"/>
  <limit lower="0" upper="0.050" effort="120" velocity="0.08"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>
<joint name="rear_pad_right_joint" type="fixed">
  <parent link="rear_suction_right"/><child link="rear_pad_right"/>
  <origin xyz="0 0 -0.032"/>
</joint>

</robot>
