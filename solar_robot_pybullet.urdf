<?xml version="1.0"?>
<robot name="solar_cleaning_robot_v2">

  <!-- Define materials -->
  <material name="black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>
  
  <material name="dark_gray">
    <color rgba="0.3 0.3 0.3 1"/>
  </material>
  
  <material name="silver">
    <color rgba="0.7 0.7 0.75 1"/>
  </material>
  
  <material name="blue">
    <color rgba="0.2 0.3 0.8 1"/>
  </material>
  
  <material name="red">
    <color rgba="0.8 0.2 0.2 1"/>
  </material>

  <material name="orange">
    <color rgba="1.0 0.5 0.0 1"/>
  </material>

  <material name="white">
    <color rgba="0.9 0.9 0.9 1"/>
  </material>

  <!-- ============================================ -->
  <!-- BASE LINK -->
  <!-- ============================================ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0"
               izz="0.00001"/>
    </inertial>
  </link>

  <!-- ============================================ -->
  <!-- MAIN ROBOT BODY (with integrated suction) -->
  <!-- Similar to HOBOT-298 window cleaner design -->
  <!-- ============================================ -->
  <link name="main_body">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="3.5"/>
      <inertia ixx="0.0146" ixy="0" ixz="0" 
               iyy="0.0208" iyz="0" 
               izz="0.0104"/>
    </inertial>
    
    <!-- Main chassis -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.40 0.35 0.10"/>
      </geometry>
      <material name="blue"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.40 0.35 0.10"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_to_main_body" type="fixed">
    <parent link="base_link"/>
    <child link="main_body"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ============================================ -->
  <!-- SUCTION PAD (Bottom of robot) -->
  <!-- Large area suction like window cleaning robots -->
  <!-- ============================================ -->
  <link name="main_suction_pad">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.002"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.38 0.33 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.38 0.33 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_to_suction" type="fixed">
    <parent link="main_body"/>
    <child link="main_suction_pad"/>
    <origin xyz="0 0 -0.06" rpy="0 0 0"/>
  </joint>

  <!-- Suction chamber visualization -->
  <link name="suction_chamber">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>

  <joint name="suction_to_chamber" type="fixed">
    <parent link="main_suction_pad"/>
    <child link="suction_chamber"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
  </joint>

  <!-- ============================================ -->
  <!-- TOP COVER / ELECTRONICS HOUSING -->
  <!-- ============================================ -->
  <link name="top_cover">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.36 0.31 0.03"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="body_to_cover" type="fixed">
    <parent link="main_body"/>
    <child link="top_cover"/>
    <origin xyz="0 0 0.065" rpy="0 0 0"/>
  </joint>

  <!-- ============================================ -->
  <!-- SENSOR ARRAY -->
  <!-- ============================================ -->
  
  <!-- LiDAR -->
  <link name="lidar_link">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_to_lidar" type="fixed">
    <parent link="top_cover"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- Depth Camera -->
  <link name="camera_link">
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0"
               izz="0.00001"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.03 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.03 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_to_camera" type="fixed">
    <parent link="main_body"/>
    <child link="camera_link"/>
    <origin xyz="0.20 0 0.02" rpy="0 0.15 0"/>
  </joint>

  <!-- IMU -->
  <link name="imu_link">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0"
               izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.01"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>

  <joint name="body_to_imu" type="fixed">
    <parent link="main_body"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
  </joint>

  <!-- ============================================ -->
  <!-- CLEANING MECHANISM (Rotating brush + squeegee) -->
  <!-- Mounted at the front -->
  <!-- ============================================ -->
  
  <!-- Brush housing -->
  <link name="brush_housing">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0"
               iyy="0.00005" iyz="0.0"
               izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.06 0.08"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.06 0.08"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_to_brush_housing" type="fixed">
    <parent link="main_body"/>
    <child link="brush_housing"/>
    <origin xyz="0.15 0 -0.01" rpy="0 0 0"/>
  </joint>

  <!-- Rotating brush -->
  <link name="rotating_brush">
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0"
               iyy="0.0005" iyz="0.0"
               izz="0.0002"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.30"/>
      </geometry>
      <material name="orange"/>
    </visual>
    
    <!-- NO COLLISION - brush should be soft/flexible, not blocking -->
  </link>

  <joint name="brush_rotation_joint" type="continuous">
    <parent link="brush_housing"/>
    <child link="rotating_brush"/>
    <origin xyz="0 0 -0.05" rpy="0 1.5708 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Water spray nozzles (visual only) -->
  <link name="water_spray_left">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0"
               izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.02"/>
      </geometry>
      <material name="silver"/>
    </visual>
  </link>

  <joint name="housing_to_spray_left" type="fixed">
    <parent link="brush_housing"/>
    <child link="water_spray_left"/>
    <origin xyz="0.05 0.12 0" rpy="0 1.5708 0"/>
  </joint>

  <link name="water_spray_right">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0"
               izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.02"/>
      </geometry>
      <material name="silver"/>
    </visual>
  </link>

  <joint name="housing_to_spray_right" type="fixed">
    <parent link="brush_housing"/>
    <child link="water_spray_right"/>
    <origin xyz="0.05 -0.12 0" rpy="0 1.5708 0"/>
  </joint>

  <!-- Squeegee -->
  <link name="squeegee">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0"
               izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.20 0.015 0.025"/>
      </geometry>
      <material name="black"/>
    </visual>
    <!-- NO COLLISION - squeegee shouldn't block movement -->
  </link>

  <joint name="brush_to_squeegee" type="fixed">
    <parent link="brush_housing"/>
    <child link="squeegee"/>
    <origin xyz="0.02 0 -0.03" rpy="0 0.2 0"/>
  </joint>

  <!-- ============================================ -->
  <!-- DEPLOYABLE BRIDGE MECHANISM -->
  <!-- Inspired by "Making Lego Car CROSS Gaps" video -->
  <!-- ============================================ -->
  
 <!-- ============================================ -->
<!-- FRONT DEPLOYABLE BRIDGE -->
<!-- ============================================ -->

<link name="bridge_compartment">
  <inertial>
    <mass value="0.2"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.0001" ixy="0" ixz="0"
             iyy="0.0001" iyz="0"
             izz="0.0001"/>
  </inertial>

  <visual>
    <geometry>
      <box size="0.08 0.30 0.06"/>
    </geometry>
    <material name="dark_gray"/>
  </visual>
</link>

<joint name="body_to_bridge_compartment" type="fixed">
  <parent link="main_body"/>
  <child link="bridge_compartment"/>
  <origin xyz="0.20 0 0.02" rpy="0 0 0"/>
</joint>


<link name="bridge_segment_1">
  <inertial>
    <mass value="0.4"/>
    <origin xyz="0.15 0 0"/>
    <inertia ixx="0.001" ixy="0" ixz="0"
             iyy="0.004" iyz="0"
             izz="0.004"/>
  </inertial>

  <visual>
    <origin xyz="0.15 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.30 0.08 0.015"/>
    </geometry>
    <material name="silver"/>
  </visual>

  <collision>
    <origin xyz="0.15 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.30 0.08 0.015"/>
    </geometry>
  </collision>
</link>


<joint name="bridge_deploy_joint_1" type="prismatic">
  <parent link="bridge_compartment"/>
  <child link="bridge_segment_1"/>
  <origin xyz="0.04 0 0.01" rpy="0 0 0"/>
  <axis xyz="1 0 0"/>
  <limit lower="0" upper="0.50" effort="50" velocity="0.2"/>
  <dynamics damping="1.0" friction="0.5"/>
</joint>


<link name="bridge_segment_2">
  <inertial>
    <mass value="0.4"/>
    <origin xyz="0.15 0 0"/>
    <inertia ixx="0.001" ixy="0" ixz="0"
             iyy="0.004" iyz="0"
             izz="0.004"/>
  </inertial>

  <visual>
    <origin xyz="0.15 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.30 0.08 0.015"/>
    </geometry>
    <material name="silver"/>
  </visual>

  <collision>
    <origin xyz="0.15 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.30 0.08 0.015"/>
    </geometry>
  </collision>
</link>


<joint name="bridge_deploy_joint_2" type="prismatic">
  <parent link="bridge_segment_1"/>
  <child link="bridge_segment_2"/>
  <origin xyz="0.30 0 0" rpy="0 0 0"/>
  <axis xyz="1 0 0"/>
  <limit lower="0" upper="0.50" effort="50" velocity="0.2"/>
  <dynamics damping="1.0" friction="0.5"/>
</joint>

  <!-- ============================================ -->
  <!-- BRIDGE SUCTION FEET -->
  <!-- Two suction pads at the end of the bridge -->
  <!-- ============================================ -->
  
  <!-- Bridge foot left - LARGE STABLE SUPPORT PAD -->
  <link name="bridge_foot_left">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 -0.03"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0"
               iyy="0.0003" iyz="0.0"
               izz="0.0003"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.06 0.06"/>
      </geometry>
      <material name="black"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.06 0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="bridge_to_foot_left" type="fixed">
    <parent link="bridge_segment_2"/>
    <child link="bridge_foot_left"/>
    <origin xyz="0.28 0.04 -0.03" rpy="0 0 0"/>
  </joint>

  <!-- Bridge foot right - LARGE STABLE SUPPORT PAD -->
  <link name="bridge_foot_right">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 -0.03"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0"
               iyy="0.0003" iyz="0.0"
               izz="0.0003"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.06 0.06"/>
      </geometry>
      <material name="black"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.06 0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="bridge_to_foot_right" type="fixed">
    <parent link="bridge_segment_2"/>
    <child link="bridge_foot_right"/>
    <origin xyz="0.28 -0.04 -0.03" rpy="0 0 0"/>
  </joint>

  <!-- ============================================ -->
  <!-- DRIVE WHEELS (4-wheel configuration for stability) -->
  <!-- Wheels at four corners of robot -->
  <!-- ============================================ -->
  
  <!-- Front Left wheel -->
  <link name="wheel_front_left">
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.00005"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_to_wheel_front_left" type="continuous">
    <parent link="main_body"/>
    <child link="wheel_front_left"/>
    <origin xyz="0.15 0.16 -0.09" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Front Right wheel -->
  <link name="wheel_front_right">
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.00005"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_to_wheel_front_right" type="continuous">
    <parent link="main_body"/>
    <child link="wheel_front_right"/>
    <origin xyz="0.15 -0.16 -0.09" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Rear Left wheel -->
  <link name="wheel_rear_left">
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.00005"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_to_wheel_rear_left" type="continuous">
    <parent link="main_body"/>
    <child link="wheel_rear_left"/>
    <origin xyz="-0.15 0.16 -0.09" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Rear Right wheel -->
  <link name="wheel_rear_right">
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.00005"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_to_wheel_rear_right" type="continuous">
    <parent link="main_body"/>
    <child link="wheel_rear_right"/>
    <origin xyz="-0.15 -0.16 -0.09" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- ============================================ -->
  <!-- FRONT SUPPORT CASTER WHEELS -->
  <!-- Small wheels at very front to prevent drooping -->
  <!-- ============================================ -->
  
  <!-- Front center left caster -->
  <link name="caster_front_left">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00002" ixy="0.0" ixz="0.0"
               iyy="0.00003" iyz="0.0"
               izz="0.00002"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_to_caster_front_left" type="fixed">
    <parent link="main_body"/>
    <child link="caster_front_left"/>
    <origin xyz="0.18 0.08 -0.08" rpy="0 0 0"/>
  </joint>

  <!-- Front center right caster -->
  <link name="caster_front_right">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00002" ixy="0.0" ixz="0.0"
               iyy="0.00003" iyz="0.0"
               izz="0.00002"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_to_caster_front_right" type="fixed">
    <parent link="main_body"/>
