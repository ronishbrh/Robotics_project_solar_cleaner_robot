<?xml version="1.0"?>
<robot name="solar_cleaning_robot">

<!--
  ╔══════════════════════════════════════════════════════════════════╗
  ║  SOLAR PANEL CLEANING ROBOT  –  Inclined-Panel Ready            ║
  ╠══════════════════════════════════════════════════════════════════╣
  ║                                                                  ║
  ║  SUCTION SYSTEM                                                  ║
  ║    • 4 wheel-corner suction pads (always in contact)            ║
  ║    • 2 front bridge tip pads  (active on next panel)            ║
  ║    • 2 rear  bridge tip pads  (active on previous panel)        ║
  ║    • PyBullet constraint force applied along -panel_normal       ║
  ║      in SuctionSystem class (not a joint – a force)             ║
  ║                                                                  ║
  ║  BODY LIFT JOINT                                                 ║
  ║    body_lift_joint  prismatic Z  0 → 0.050 m                    ║
  ║    Lifts wheels clear of panel for gap traversal                 ║
  ║                                                                  ║
  ║  BRIDGE                                                          ║
  ║    front/rear_bridge_extend1  prismatic  0 → 0.40 m             ║
  ║    front/rear_bridge_extend2  prismatic  0 → 0.30 m             ║
  ║    Tip at full extension: ~1.05 m from body centre              ║
  ║                                                                  ║
  ║  ACTIVE SUCTION LEGS (bridge tip, prismatic -Z)                  ║
  ║    front/rear_suction_left/right_joint  0 → 0.050 m             ║
  ╚══════════════════════════════════════════════════════════════════╝
-->

<!-- ═══════════════ MATERIALS ═══════════════ -->
<material name="blue">   <color rgba="0.2  0.3  0.8  1"/></material>
<material name="dark_blue"><color rgba="0.1 0.15 0.5  1"/></material>
<material name="black">  <color rgba="0.1  0.1  0.1  1"/></material>
<material name="silver">  <color rgba="0.72 0.72 0.72 1"/></material>
<material name="orange">  <color rgba="1.0  0.45 0.0  1"/></material>
<material name="red">     <color rgba="0.85 0.1  0.1  1"/></material>
<material name="green">   <color rgba="0.1  0.75 0.2  1"/></material>
<material name="yellow">  <color rgba="0.95 0.85 0.1  1"/></material>


<!-- ═══════════════ BASE LINK ═══════════════ -->
<link name="base_link"/>


<!-- ═══════════════ MAIN BODY ═══════════════ -->
<link name="main_body">
  <inertial>
    <origin xyz="0 0 0"/>
    <mass value="3.2"/>
    <inertia ixx="0.038" ixy="0" ixz="0"
             iyy="0.028" iyz="0" izz="0.055"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0"/>
    <geometry><box size="0.35 0.35 0.12"/></geometry>
    <material name="blue"/>
  </visual>
  <collision>
    <origin xyz="0 0 0"/>
    <geometry><box size="0.35 0.35 0.12"/></geometry>
  </collision>
</link>

<joint name="body_to_chassis" type="fixed">
  <parent link="base_link"/>
  <child  link="main_body"/>
  <origin xyz="0 0 0"/>
</joint>
<!-- ═══════════════ SENSORS ═══════════════ -->
<link name="lidar">
  <visual><geometry><cylinder radius="0.02" length="0.04"/></geometry>
    <material name="black"/></visual>
</link>

<joint name="lidar_joint" type="fixed">
  <parent link="main_body"/><child link="lidar"/>
  <origin xyz="0.198 0 .01" rpy="0 0 1.5708"/>
</joint>

<!-- 
<link name="camera">
  <visual><geometry><box size="0.05 0.025 0.025"/></geometry>
    <material name="black"/></visual>
</link>
<joint name="camera_joint" type="fixed">
  <parent link="main_body"/><child link="camera"/>
  <origin xyz="0.225 0 0.04"/>
</joint>
-->

<!-- ═══════════════ CLEANING BRUSH ═══════════════ -->
<!-- 
<link name="brush">
  <inertial>
    <origin xyz="0 0 0"/>
    <mass value="0.14"/>
    <inertia ixx="0.0002" ixy="0" ixz="0"
             iyy="0.0002" iyz="0" izz="0.0002"/>
  </inertial>
  <visual>
    <geometry><cylinder radius="0.038" length="0.32"/></geometry>
    <material name="orange"/>
  </visual>
  <collision>
    <geometry><cylinder radius="0.038" length="0.32"/></geometry>
  </collision>
</link>
<joint name="brush_joint" type="continuous">
  <parent link="main_body"/><child link="brush"/>
  <origin xyz="0.20 0 -0.055" rpy="0 1.5708 0"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="0.05" friction="0.02"/>
</joint>

-->

<!-- ═══════════════════════════════════════════════════ -->
<!--  WHEELS  (plain rolling wheels, no suction pads)    -->
<!--  Suction for inclined panels is handled entirely    -->
<!--  via applyExternalForce in the Python environment.  -->
<!--  Fixed suction pads at wheel level block movement.  -->
<!-- ═══════════════════════════════════════════════════ -->

<!-- ── Front-Left ── -->
<link name="wheel_fl">
  <inertial><origin xyz="0 0 0"/><mass value="0.20"/>
    <inertia ixx="0.00015" ixy="0" ixz="0"
             iyy="0.00015" iyz="0" izz="0.00025"/></inertial>
  <visual><geometry><cylinder radius="0.035" length="0.022"/></geometry>
    <material name="black"/></visual>
  <collision><geometry><cylinder radius="0.035" length="0.022"/></geometry></collision>
</link>
<joint name="wheel_fl_joint" type="continuous">
  <parent link="main_body"/><child link="wheel_fl"/>
  <origin xyz="0.14 0.175 -0.07" rpy="1.5708 0 0"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="0.0" friction="0.0"/>
</joint>

<!-- ── Front-Right ── -->
<link name="wheel_fr">
  <inertial><origin xyz="0 0 0"/><mass value="0.20"/>
    <inertia ixx="0.00015" ixy="0" ixz="0"
             iyy="0.00015" iyz="0" izz="0.00025"/></inertial>
  <visual><geometry><cylinder radius="0.035" length="0.022"/></geometry>
    <material name="black"/></visual>
  <collision><geometry><cylinder radius="0.035" length="0.022"/></geometry></collision>
</link>
<joint name="wheel_fr_joint" type="continuous">
  <parent link="main_body"/><child link="wheel_fr"/>
  <origin xyz="0.14 -0.175 -0.07" rpy="1.5708 0 0"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="0.0" friction="0.0"/>
</joint>

<!-- ── Rear-Left ── -->
<link name="wheel_rl">
  <inertial><origin xyz="0 0 0"/><mass value="0.20"/>
    <inertia ixx="0.00015" ixy="0" ixz="0"
             iyy="0.00015" iyz="0" izz="0.00025"/></inertial>
  <visual><geometry><cylinder radius="0.035" length="0.022"/></geometry>
    <material name="black"/></visual>
  <collision><geometry><cylinder radius="0.035" length="0.022"/></geometry></collision>
</link>
<joint name="wheel_rl_joint" type="continuous">
  <parent link="main_body"/><child link="wheel_rl"/>
  <origin xyz="-0.14 0.175 -0.07" rpy="1.5708 0 0"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="0.0" friction="0.0"/>
</joint>

<!-- ── Rear-Right ── -->
<link name="wheel_rr">
  <inertial><origin xyz="0 0 0"/><mass value="0.20"/>
    <inertia ixx="0.00015" ixy="0" ixz="0"
             iyy="0.00015" iyz="0" izz="0.00025"/></inertial>
  <visual><geometry><cylinder radius="0.035" length="0.022"/></geometry>
    <material name="black"/></visual>
  <collision><geometry><cylinder radius="0.035" length="0.022"/></geometry></collision>
</link>
<joint name="wheel_rr_joint" type="continuous">
  <parent link="main_body"/><child link="wheel_rr"/>
  <origin xyz="-0.14 -0.175 -0.07" rpy="1.5708 0 0"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="0.0" friction="0.0"/>
</joint>





<!-- ================= VERTICAL COLUMN ================= -->
<link name="lift_column">
  <inertial>
    <mass value="0.3"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.002" iyy="0.002" izz="0.002" ixy="0" ixz="0" iyz="0"/>
  </inertial>
  <visual>
    <geometry>
      <cylinder radius="0.02" length="0.11"/>
    </geometry>
    <material name="silver"/>
  </visual>
</link>

<joint name="lift_column_joint" type="prismatic">
  <parent link="base_link"/>
  <child link="lift_column"/>
  <origin xyz="0 0 0.108"/>
  <axis xyz="0 0 1"/>
  <limit lower="-.1" upper="0" effort="500" velocity="0.2"/>
</joint>

<!-- ================= BRIDGE ================= -->
<link name="bridge_link">
  <inertial>
    <mass value=".6"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.02" iyy="0.02" izz="0.02" ixy="0" ixz="0" iyz="0"/>
  </inertial>

  <visual>
    <geometry>
      <box size="1.2 0.04 0.04"/>
    </geometry>
    <material name="silver"/>
  </visual>

  <collision>
    <geometry>
      <box size="1.2 0.08 0.06"/>
    </geometry>
  </collision>
</link>

<joint name="bridge_mount" type="prismatic">
  <parent link="bridge_carriage"/>
  <child link="bridge_link"/>
  <origin xyz="0 0 0"/>
  <axis xyz="1 0 0"/>
  <limit lower="-.95" upper=".95" effort="400" velocity="0.4"/>
</joint>

<!-- ================= ROBOT SLIDING CARRIAGE ================= -->
<link name="bridge_carriage">
  <visual>
    <geometry>
      <box size="0.06 0.06 0.06"/>
    </geometry>
    <material name="black"/>
  </visual>
</link>

<joint name="column_carriage_joint" type="fixed">
  <parent link="lift_column"/>
  <child link="bridge_carriage"/>
  <origin xyz="0 0 0.085"/>
</joint>

<!-- ================= BRIDGE SUCTION LEGS ================= -->

<link name="front_column">
  <visual>
    <geometry><cylinder radius="0.02" length="0.20"/></geometry>
    <material name="silver"/>
  </visual>
</link>

<joint name="front_column_bridge_joint" type="fixed">
  <parent link="bridge_link"/>
  <child link="front_column"/>
  <origin xyz=".58 0 -0.12"/>
</joint>

<link name="front_plate">
  <visual>
  <geometry><box size="0.06 0.24 0.02"/></geometry>
    <material name="silver"/>
  </visual>
</link>

<joint name="front_plate_column_joint" type="fixed">
  <parent link="front_column"/>
  <child link="front_plate"/>
  <origin xyz="0 0 -0.11"/>
</joint>

<link name="front_left_pad">
  <visual>
    <geometry><cylinder radius="0.03" length="0.01"/></geometry>
    <material name="red"/>
  </visual>

  <collision>
    <origin xyz="0 0 0"/>
    <geometry><cylinder radius="0.03" length="0.01"/></geometry>
  </collision>
</link>

<joint name="front_left_pad_joint" type="fixed">
  <parent link="front_plate"/>
  <child link="front_left_pad"/>
  <origin xyz="0 0.09 -0.015"/>
</joint>

<link name="front_right_pad">
  <visual>
    <geometry><cylinder radius="0.03" length="0.01"/></geometry>
    <material name="red"/>
  </visual>
  <collision>
    <origin xyz="0 0 0"/>
    <geometry><cylinder radius="0.03" length="0.01"/></geometry>
  </collision>
</link>

<joint name="front_right_pad_joint" type="fixed">
  <parent link="front_plate"/>
  <child link="front_right_pad"/>
  <origin xyz="0 -0.09 -0.015"/>
</joint>

<link name="rear_column">
  <visual>
    <geometry><cylinder radius="0.02" length="0.2"/></geometry>
    <material name="silver"/>
  </visual>
</link>

<joint name="rear_column_bridge_joint" type="fixed">
  <parent link="bridge_link"/>
  <child link="rear_column"/>
  <origin xyz="-0.58 0 -0.12"/>
</joint>

<link name="rear_plate">
  <visual>
  <geometry><box size="0.06 0.24 0.02"/></geometry>
    <material name="silver"/>
  </visual>
</link>

<joint name="rear_plate_column_joint" type="fixed">
  <parent link="rear_column"/>
  <child link="rear_plate"/>
  <origin xyz="0 0 -0.11"/>
</joint>

<link name="rear_left_pad">
  <visual>
    <geometry><cylinder radius="0.03" length="0.01"/></geometry>
    <material name="red"/>
  </visual>
  <collision>
    <origin xyz="0 0 0"/>
    <geometry><cylinder radius="0.03" length="0.01"/></geometry>
  </collision>
</link>

<joint name="rear_left_pad_joint" type="fixed">
  <parent link="rear_plate"/>
  <child link="rear_left_pad"/>
  <origin xyz="0 0.09 -0.015"/>
</joint>

<link name="rear_right_pad">
  <visual>
    <geometry><cylinder radius="0.03" length="0.01"/></geometry>
    <material name="red"/>
  </visual>
  <collision>
    <origin xyz="0 0 0"/>
    <geometry><cylinder radius="0.03" length="0.01"/></geometry>
  </collision>
</link>

<joint name="rear_right_pad_joint" type="fixed">
  <parent link="rear_plate"/>
  <child link="rear_right_pad"/>
  <origin xyz="0 -0.09 -0.015"/>
</joint>

</robot>
